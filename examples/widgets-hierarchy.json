    {
      "id": "1",
      "level": 1,
      "tag": "unit",
      "parent": null,
      "ordinal": 1,
      "is_leaf": false,
      "text": "Widget Basics\n\nAn introductory unit covering what widgets are and how they go together. This is\na synthetic, entirely fictional course used as a worked example and as a\nreference for the hierarchy-markdown format the tool ingests."
    },
    {
      "id": "1.1",
      "level": 2,
      "tag": "topic",
      "parent": "1",
      "ordinal": 1,
      "is_leaf": false,
      "text": "What Is a Widget\n\nThe vocabulary of widgets and their parts."
    },
    {
      "id": "1.1.A",
      "level": 3,
      "tag": "learning-objective",
      "parent": "1.1",
      "ordinal": 1,
      "is_leaf": false,
      "text": "Describe the parts of a widget"
    },
    {
      "id": "1.1.A.1",
      "level": 4,
      "tag": "essential-knowledge",
      "parent": "1.1.A",
      "ordinal": 1,
      "is_leaf": true,
      "text": "A widget has a frobnicator and a sprocket."
    },
    {
      "id": "1.1.A.2",
      "level": 4,
      "tag": "essential-knowledge",
      "parent": "1.1.A",
      "ordinal": 2,
      "is_leaf": true,
      "text": "The frobnicator controls the widget's spin."
    },
    {
      "id": "1.1.B",
      "level": 3,
      "tag": "learning-objective",
      "parent": "1.1",
      "ordinal": 2,
      "is_leaf": false,
      "text": "Compare widget types"
    },
    {
      "id": "1.1.B.1",
      "level": 4,
      "tag": "essential-knowledge",
      "parent": "1.1.B",
      "ordinal": 1,
      "is_leaf": true,
      "text": "A round widget rolls; a square widget does not."
    },
    {
      "id": "1.2",
      "level": 2,
      "tag": "topic",
      "parent": "1",
      "ordinal": 2,
      "is_leaf": false,
      "text": "Assembling Widgets\n\nPutting the parts together in the right order."
    },
    {
      "id": "1.2.A",
      "level": 3,
      "tag": "learning-objective",
      "parent": "1.2",
      "ordinal": 1,
      "is_leaf": false,
      "text": "Order the steps to assemble a widget"
    },
    {
      "id": "1.2.A.1",
      "level": 4,
      "tag": "essential-knowledge",
      "parent": "1.2.A",
      "ordinal": 1,
      "is_leaf": true,
      "text": "Attach the sprocket before the frobnicator."
    },
    {
      "id": "1.2.A.2",
      "level": 4,
      "tag": "essential-knowledge",
      "parent": "1.2.A",
      "ordinal": 2,
      "is_leaf": true,
      "text": "Tighten every bolt to the same torque."
    },
    {
      "id": "2",
      "level": 1,
      "tag": "unit",
      "parent": null,
      "ordinal": 2,
      "is_leaf": false,
      "text": "Advanced Widgetry\n\nA second unit on keeping widgets running."
    },
    {
      "id": "2.1",
      "level": 2,
      "tag": "topic",
      "parent": "2",
      "ordinal": 1,
      "is_leaf": false,
      "text": "Widget Maintenance\n\nDiagnosing and fixing common widget faults."
    },
    {
      "id": "2.1.A",
      "level": 3,
      "tag": "learning-objective",
      "parent": "2.1",
      "ordinal": 1,
      "is_leaf": false,
      "text": "Diagnose a stuck frobnicator"
    },
    {
      "id": "2.1.A.1",
      "level": 4,
      "tag": "essential-knowledge",
      "parent": "2.1.A",
      "ordinal": 1,
      "is_leaf": true,
      "text": "A stuck frobnicator usually needs lubrication."
    },
    {
      "id": "2.1.A.2",
      "level": 4,
      "tag": "essential-knowledge",
      "parent": "2.1.A",
      "ordinal": 2,
      "is_leaf": true,
      "text": "Replace a cracked sprocket before it fails."
    }
  ]
}
